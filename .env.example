# ===================================
# DTR TRACKER - BACKEND ENVIRONMENT VARIABLES
# ===================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ===================================
# SERVER CONFIGURATION
# ===================================

# Port the server will listen on
# - Local: Use 3000 or any available port
# - Production (Heroku): DO NOT SET THIS! Heroku assigns PORT automatically via process.env.PORT
# - Production (Railway/Render): Same as Heroku, they assign the port
PORT=3000

# Node environment (development | production | test)
# - Controls error verbosity, logging, and optimizations
# - Production: Set to "production" for security hardening
NODE_ENV=development


# ===================================
# DATABASE CONFIGURATION
# ===================================

# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?[params]
# 
# Local development:
DATABASE_URL=postgresql://username:password@localhost:5432/dtr_db
#
# Production (Heroku Postgres):
# DATABASE_URL=postgresql://user:pass@ec2-xx-xxx-xxx-xx.compute-1.amazonaws.com:5432/dbname?sslmode=require
#
# Production (Supabase):
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
#
# Production (Neon/Railway):
# DATABASE_URL=postgresql://user:pass@host.region.provider.com:5432/dbname?sslmode=require
#
# SECURITY: Always use SSL in production (?sslmode=require)


# ===================================
# AUTHENTICATION CONFIGURATION
# ===================================

# Better-Auth secret key for signing JWTs and session tokens
# CRITICAL: Generate a strong random secret for production
# Generate with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Better-Auth base URL (where this backend is accessible)
# - Local: http://localhost:8080
# - Production (Heroku): https://your-app-name.herokuapp.com
# - Production (Railway): https://your-app.railway.app
# - Custom domain: https://api.yourdomain.com
BETTER_AUTH_URL=http://localhost:8080

# Cookie domain for cross-domain authentication
# - Local: Leave empty or set to "localhost"
# - Production: Set to your root domain (e.g., ".yourdomain.com" to share cookies across subdomains)
# - SameSite attribute is set to "lax" in production, "none" requires HTTPS
# IMPORTANT: Must match your frontend domain structure
COOKIE_DOMAIN=


# ===================================
# FRONTEND / CORS CONFIGURATION
# ===================================

# Allowed frontend origin(s) for CORS
# Supports:
# 1. Single origin:
#    FRONTEND_ORIGIN=http://localhost:3000
#
# 2. Multiple origins (comma-separated):
#    FRONTEND_ORIGIN=http://localhost:3000,https://your-app.vercel.app
#
# 3. Wildcard patterns for preview deployments:
#    FRONTEND_ORIGIN=http://localhost:3000,https://*.vercel.app,https://your-app.vercel.app
#
# Production examples:
# - Vercel (with preview deployments):
#   FRONTEND_ORIGIN=https://your-app.vercel.app,https://*.vercel.app
#
# - Netlify (with preview deployments):
#   FRONTEND_ORIGIN=https://your-app.netlify.app,https://*--your-app.netlify.app
#
# - Custom domain + Vercel previews:
#   FRONTEND_ORIGIN=https://dtr.yourdomain.com,https://*.vercel.app
#
# - Development + Production:
#   FRONTEND_ORIGIN=http://localhost:3000,https://your-app.vercel.app,https://*.vercel.app
#
# SECURITY NOTES:
# - NEVER use "*" alone in production (use specific wildcard patterns instead)
# - Always use HTTPS in production
# - Wildcard patterns are validated with regex (e.g., *.vercel.app only matches Vercel subdomains)
# - For local development, http://localhost:3000 is required

# Default for local development:
FRONTEND_ORIGIN=http://localhost:3000

# App timezone used for cron and date-based features
APP_TIMEZONE=Asia/Manila

# ===================================
# GEOFENCING CONFIGURATION
# ===================================
# Office coordinates used to classify timestamps as On-site vs Remote
# Leave empty to disable distance computation and default logs to Remote.
OFFICE_LATITUDE=
OFFICE_LONGITUDE=
OFFICE_RADIUS_METERS=50

# ===================================
# PUBLIC HOLIDAY INTEGRATION
# ===================================
# ISO country code for holiday lookups (PH = Philippines)
HOLIDAY_COUNTRY_CODE=PH

# Base URL for Nager public holiday API
HOLIDAY_API_BASE_URL=https://date.nager.at/api/v3


# ===================================
# PRODUCTION-SPECIFIC SETTINGS
# ===================================

# Enable trust proxy (required for Heroku, Railway, behind load balancers)
# Set to "true" in production to correctly parse X-Forwarded-* headers
# TRUST_PROXY=true

# Log level (error | warn | info | debug)
# Production: Use "info" or "warn" to reduce noise
# LOG_LEVEL=info

# Rate limiting (requests per window)
# Prevents abuse; adjust based on your expected traffic
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100


# ===================================
# DEPLOYMENT CHECKLIST
# ===================================
# Before deploying to production:
# ✅ Set NODE_ENV=production
# ✅ Generate strong BETTER_AUTH_SECRET (32+ chars, random)
# ✅ Use HTTPS for BETTER_AUTH_URL and FRONTEND_ORIGIN
# ✅ Add ?sslmode=require to DATABASE_URL
# ✅ Set COOKIE_DOMAIN to your root domain if using subdomains
# ✅ Configure CORS to allow only your frontend domain
# ✅ Enable TRUST_PROXY if behind a reverse proxy/load balancer
# ✅ NEVER commit .env file to git (check .gitignore)
