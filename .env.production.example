# ============================================================================
# DTR TRACKER - PRODUCTION ENVIRONMENT TEMPLATE
# For: Heroku Backend + Vercel Frontend Deployment
# ============================================================================

# --- Core Server ---
PORT=3000

# --- Database ---
# PostgreSQL connection string (usually provided by Heroku as DATABASE_URL)
# Format: postgres://username:password@host:port/dbname
DATABASE_URL=postgres://user:password@hostname:5432/dtr_db

# --- Authentication ---
# Better Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl

# Better Auth base URL (your backend URL)
# For Heroku: https://your-app-name.herokuapp.com
BETTER_AUTH_URL=https://your-app-name.herokuapp.com

# --- Frontend Origin (CRITICAL FOR CORS + CSRF) ---
# Comma-separated list of allowed frontend origins
# For Vercel:
#   - Production domain: https://yourapp.vercel.app
#   - Git branch previews: https://*.vercel.app (matches all preview deploys)
#   - Custom domain: https://yourdomain.com
# 
# Examples:
#   Single domain:     https://yourapp.vercel.app
#   With preview:      https://yourapp.vercel.app,https://*.vercel.app
#   Multiple domains:  https://yourapp.vercel.app,https://yourdomain.com
#   Development:       http://localhost:3000
FRONTEND_ORIGIN=https://yourapp.vercel.app,https://*.vercel.app

# --- Proxy Trust (for Heroku) ---
# Heroku sits behind proxies; this tells Express to trust X-Forwarded-* headers
# Value: 1 (trust one proxy, standard for Heroku)
#        true/false (for direct deployment)
#        N (integer for N proxies in chain)
TRUST_PROXY=1

# --- Timezone ---
# App timezone for cron jobs and date calculations
# Common values: Asia/Manila, America/New_York, Europe/London, UTC
APP_TIMEZONE=Asia/Manila

# --- Office Location (for geofencing) ---
# Optional. Set both to enable "On-site" classification.
# Example for Manila: 14.5794, 121.0202
# Leave unset to disable location-based tracking
OFFICE_LATITUDE=14.5794
OFFICE_LONGITUDE=121.0202
OFFICE_RADIUS_METERS=50

# --- Holidays Configuration ---
# Country code for public holidays (2-3 char ISO 3166-1 alpha-2/3)
# Examples: PH (Philippines), US (USA), GB (UK), JP (Japan)
HOLIDAY_COUNTRY_CODE=PH

# Holiday API endpoint (default uses Nager API)
HOLIDAY_API_BASE_URL=https://date.nager.at/api/v3

# Enable/disable holiday calendar cron sync (true/false)
ENABLE_HOLIDAY_CRON=true

# --- Internal Automation Secret ---
# Secret header for internal n8n/automation endpoints
# Generate with: openssl rand -base64 32
# Used to protect /api/v1/automation/internal/holidays/sync
# Leave unset to disable this endpoint
INTERNAL_AUTOMATION_SECRET=your-internal-secret-here-generate-with-openssl

# --- Rate Limiting ---
# Auth endpoint: login, signup, session endpoints
# Default: 100 requests per 15 minutes
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000

# Automation endpoint: holiday sync, geofence webhooks
# Default: 60 requests per 15 minutes
RATE_LIMIT_AUTOMATION_MAX=60
RATE_LIMIT_AUTOMATION_WINDOW_MS=900000

# User API endpoint: logs, daily-notes, users, geofence-entry
# Default: 120 requests per 15 minutes (per user+IP combo)
RATE_LIMIT_USER_MAX=120
RATE_LIMIT_USER_WINDOW_MS=900000

# --- n8n Webhook Integration (Optional) ---
# URL to your n8n geofence trigger webhook
# Leave unset to disable geofence reminders
N8N_GEOFENCE_WEBHOOK_URL=https://your-n8n-instance.com/webhook/geofence

# Secret header for n8n webhook validation
# Set if your n8n webhook requires x-webhook-secret header
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# --- Daily Motivation (Optional) ---
# API Ninjas API key for daily motivational quotes
# Get free API key at: https://api-ninjas.com
# Leave unset to disable external quotes (will use default message)
API_NINJAS_KEY=your-api-ninjas-key

# API Ninjas quotes endpoint (default is correct)
API_NINJAS_QUOTES_URL=https://api.api-ninjas.com/v2/quotes

# Comma-separated quote categories to fetch
API_NINJAS_QUOTE_CATEGORIES=success,wisdom

# ============================================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================================
#
# 1. HEROKU SETUP:
#    - Rename this file to .env.production (or add vars to Heroku config)
#    - For DATABASE_URL: Heroku provides this automatically if you add Postgres addon
#    - Deploy: git push heroku main
#
# 2. GENERATE SECRETS:
#    $ openssl rand -base64 32  # For BETTER_AUTH_SECRET and INTERNAL_AUTOMATION_SECRET
#
# 3. VERCEL FRONTEND:
#    - Set NEXT_PUBLIC_APP_URL to your Heroku backend URL
#    - Example: https://your-app-name.herokuapp.com
#
# 4. CRITICAL CHECKS BEFORE PRODUCTION:
#    ✓ FRONTEND_ORIGIN is set correctly (includes your Vercel domain)
#    ✓ TRUST_PROXY=1 (for Heroku)
#    ✓ DATABASE_URL is set (Heroku Postgres addon)
#    ✓ BETTER_AUTH_SECRET and BETTER_AUTH_URL are set
#    ✓ Secrets are strong (use openssl rand -base64 32)
#
# 5. MONITORING:
#    - Watch Heroku logs: heroku logs --tail
#    - Security events appear as [security] in logs
#    - CORS/CSRF rejections logged with context
#
# ============================================================================
